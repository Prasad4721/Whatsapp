# Copy this file to .env and fill in your real values.
# Never commit your real .env file to git.

# --- Groq API ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model to use for analysis. llama-3.3-70b-versatile is a good default.
GROQ_MODEL=llama-3.3-70b-versatile

# --- Behavior ---
# Minimum characters before a message is even sent for AI analysis.
# Short messages ("ok", "haha") are handled locally without an API call.
TRIAGE_MIN_LENGTH=12

# Priority score (0-100) at/above which the user is notified in the terminal.
NOTIFY_THRESHOLD=60

# Daily brief / evening report / weekly analytics schedule (cron format, 24h, local time)
DAILY_BRIEF_CRON=0 8 * * *
EVENING_REPORT_CRON=0 21 * * *
WEEKLY_ANALYTICS_CRON=0 9 * * 0

# --- WhatsApp ---
# Ignore WhatsApp group chats entirely (true/false)
IGNORE_GROUPS=false

# Ignore WhatsApp broadcast/status updates (true/false) - recommended true
IGNORE_STATUS=true

# --- Logging ---
LOG_LEVEL=info
LOG_DIR=./logs
